<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_zoom_attendance_list" model="ir.ui.view">
        <field name="name">zoom.attendance.list</field>
        <field name="model">zoom.attendance</field>
        <field name="arch" type="xml">
            <list string="Zoom Attendances">
                <field name="name"/>
                <field name="email"/>
                <field name="join_time"/>
                <field name="leave_time"/>
                <field name="duration"/>
                <field name="event_id"/>
                <field name="company_name"/>
            </list>
        </field>
    </record>

    <record id="view_zoom_attendance_form" model="ir.ui.view">
        <field name="name">zoom.attendance.form</field>
        <field name="model">zoom.attendance</field>
        <field name="arch" type="xml">
            <form string="Zoom Attendance">
                <group>
                    <field name="name"/>
                    <field name="email"/>
                    <field name="join_time"/>
                    <field name="leave_time"/>
                    <field name="duration" string="Duration"/>
                    <field name="event_id" invisible="1"/>
                    <field name="company_name"/>
<!--                    <field name="status"/>-->
                </group>
            </form>
        </field>
    </record>

    <record id="action_zoom_attendance" model="ir.actions.act_window">
        <field name="name">Zoom Attendances</field>
        <field name="res_model">zoom.attendance</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No Zoom attendance records found.
            </p>
        </field>
    </record>

    <menuitem id="menu_zoom_attendance" name="Attendances" parent="event.menu_reporting_events"
              action="action_zoom_attendance"/>
</odoo>