<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_event_pr_report" model="ir.ui.view">
        <field name="name">event.pr.report.wizard.form</field>
        <field name="model">event.pr.report.wizard</field>
        <field name="arch" type="xml">
            <form string="MP Report">
                <group>
                    <field name="start_date"/>
                    <field name="end_date"/>
                    <field name="tag_ids" widget="many2many_tags"/>
                    <field name="mode"/>
                </group>
                <footer>
                    <button name="action_button" string="Confirm" type="object" class="btn-primary" data-hotkey="q"/>
                    <button string="Cancel" class="btn-secondary" special="cancel" data-hotkey="x" />
                </footer>
            </form>
        </field>
    </record>

</odoo>