<odoo>
    <data>

        <record id="action_mp_report" model="ir.actions.act_window">
            <field name="name">MP Report</field>
            <field name="res_model">event.mp.report.wizard</field>
            <field name="view_mode">form</field>
            <field name="view_id" ref="view_event_mp_report"/>
            <field name="target">new</field> 
            <field name="context">{}</field>
        </record>

        <record id="action_pr_report" model="ir.actions.act_window">
            <field name="name">PR Report</field>
            <field name="res_model">event.pr.report.wizard</field>
            <field name="view_mode">form</field>
            <field name="view_id" ref="view_event_pr_report"/>
            <field name="target">new</field> 
            <field name="context">{}</field>
        </record>

        
        <menuitem id="mp_report" 
                  name="MP Report"
                  parent="event.menu_reporting_events"
                  action="action_mp_report"
                  sequence="51"/>
        

        <menuitem id="pr_report" 
                  name="PR Report"
                  parent="event.menu_reporting_events"
                  action="action_pr_report"
                  sequence="51"/>

    </data>
</odoo>