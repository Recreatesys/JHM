<odoo>
    <data>
        <!--DAILY FREE EVENTS-->
        <record id="email_template_daily_free_events" model="mail.template">
            <field name="name">Daily Free Events Summary</field>
            <field name="model_id" ref="event.model_event_event"/>
            <field name="subject">Free Event Registrations Summary</field>
            <field name="email_from">{{ user.company_id.email }}</field>
            <field name="email_to">{{ object.user_id.email_formatted }}</field>
            <field name="body_html" type="html">
                <h2 class="text-primary">Daily Free Events Summary - <t t-out="ctx.get('default_today_date') or ''"/></h2>
                <p class="mb-3">Hello <t t-out="object.user_id.name"/></p>
                <p>Here's your summary of ongoing <strong>free events</strong> and their registration status for today:</p>
                <t t-if="ctx.get('default_event_data') and len(ctx.get('default_event_data')) > 0">
                    <div style="font-family: Arial, sans-serif;">
                        <t t-foreach="ctx['default_event_data']" t-as="ev">
                            <div style="
                background-color: #f9f9f9;
                border: 1px solid #ddd;
                border-radius: 8px;
                padding: 16px;
                margin-bottom: 20px;
                max-width: 20%;
                box-shadow: 1px 1px 6px rgba(0,0,0,0.05);">

                                <h2 style="
                    color: #34495e;
                    font-size: 18px;
                    margin-bottom: 12px;
                    border-bottom: 1px solid #ccc;
                    padding-bottom: 6px;">
                                    <t t-out="ev['name']"/>
                                </h2>

                                <p style="margin: 6px 0;">
                                    <strong>Total Registrations:</strong>
                                    <span style="color: #2c3e50;"><t t-out="ev['total_registrations']"/></span>
                                </p>

                                <p style="margin: 6px 0;">
                                    <strong>Today's Registrations:</strong>
                                    <span style="color: #2c3e50;"><t t-out="ev['today_total_registrations']"/></span>
                                </p>
                            </div>
                        </t>
                    </div>
                </t>
                <t t-else="">
                    <p class="text-muted">No free events Found for today.</p>
                </t>
                <p class="mt-4">Best regards,<br/><strong>Odoo System</strong></p>
            </field>
        </record>

        <!-- PAID EVENTS-->
        <record id="email_template_event_summary" model="mail.template">
            <field name="name">Event Registration Summary</field>
            <field name="model_id" ref="event.model_event_event"/>
            <field name="subject">Daily Registration Summary</field>
            <field name="email_from">{{ user.company_id.email }}</field>
            <field name="email_to">{{ object.user_id.email_formatted }}</field>
            <field name="body_html" type="html">
                <div>
                    <p>Dear <t t-out="object.user_id.name"/>,</p>
                    <p>Here's your <strong>daily summary</strong> for the event <strong><t t-out="ctx.get('name')"/></strong>:</p>
                    <ul>
                        <li><strong>New Registrations Today:</strong><t t-out="ctx.get('new_regs')"/></li>
                        <li><strong>Total Registrations:</strong><t t-out="ctx.get('total_regs')"/></li>
                    </ul>
                    <p>Keep up the great work!</p>
                    <p>Regards,<br/>Odoo Automated Report System</p>
                </div>
            </field>
        </record>

        <!-- POST EVENT ABSENTEES MAIL-->
