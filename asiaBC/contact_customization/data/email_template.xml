<odoo>
    <!-- Payment Receipt Template -->
    <record id="email_template_payment_receipt_custom" model="mail.template">
        <field name="name">Payment Receipt - Custom</field>
        <field name="model_id" ref="account.model_account_payment"/>
        <field name="email_from">{{ (object.company_id.email_formatted or user.email_formatted) }}</field>
        <field name="partner_to">{{ object.partner_id.id }}</field>
        <field name="subject">{{ object.company_id.name }} - Payment Receipt ({{ object.name or 'n/a' }})</field>
        <field name="description">Sent to customers with their payment receipt attached</field>
        <field name="body_html" type="html">
            <div style="margin: 0px; padding: 0px;">
                <p style="font-size: 13px;">
                    Dear <t t-out="object.partner_id.name or ''"></t>,
                    <br/>
                    We have received your payment. Below are the details:
                    <ul>
                        <li><strong>Receipt Number:</strong> <t t-out="object.name or ''"/></li>
                        <li><strong>Receipt Date:</strong> <t t-out="object.date or ''"/></li>
                        <li><strong>Payment Reference:</strong> <t t-out="object.ref or ''"/></li>
                        <li><strong>Amount Paid:</strong> <t t-out="format_amount(object.amount, object.currency_id)"/></li>
                        <li><strong>Journal:</strong> <t t-out="object.journal_id.name or ''"/></li>
                    </ul>
                    <t t-if="object.state == 'posted'">
                        Your payment has been successfully posted.
                    </t>
                    <br/>
                    Thank you for your payment.
                    <br/>
                    Best regards,<br/>
                    <t t-out="object.company_id.name or ''"/>
                    <t t-if="not is_html_empty(user.signature)">
                        <br/><br/><t t-out="user.signature or ''"/>
                    </t>
                </p>
            </div>
        </field>
        <field name="report_template_ids" eval="[(4, ref('account.action_report_payment_receipt'))]"/>
        <field name="lang">{{ object.partner_id.lang }}</field>
        <field name="auto_delete" eval="True"/>
    </record>

    <!-- Reminder Templates -->
    <record id="email_template_registration_reminder" model="mail.template">
        <field name="name">Registration Renewal Reminder</field>
        <field name="model_id" ref="base.model_res_partner"/>
        <field name="email_from">{{ (object.company_id.email_formatted or user.email_formatted) }}</field>
        <field name="partner_to">{{ object.id }}</field>
        <field name="subject">Registration Renewal Reminder for {{ object.name }}</field>
        <field name="body_html" type="html">
            <div>
                <p>Dear <t t-out="object.name or ''"/>,</p>
                <p>Your registration is due for renewal. Please take necessary action.</p>
                <p>Best regards,<br/>Company</p>
            </div>
        </field>
        <field name="lang">{{ object.lang }}</field>
        <field name="auto_delete" eval="True"/>
    </record>

    <record id="email_template_ptr_reminder" model="mail.template">
        <field name="name">PTR Letter Follow-up</field>
        <field name="model_id" ref="base.model_res_partner"/>
        <field name="email_from">{{ (object.company_id.email_formatted or user.email_formatted) }}</field>
        <field name="partner_to">{{ object.id }}</field>
        <field name="subject">PTR Letter Follow-up for {{ object.name }}</field>
        <field name="body_html" type="html">
            <div>
                <p>Dear <t t-out="object.name or ''"/>,</p>
                <p>This is a follow-up regarding your PTR Letter. Please check and respond if needed.</p>
                <p>Best regards,<br/>Company</p>
            </div>
        </field>
        <field name="lang">{{ object.lang }}</field>
        <field name="auto_delete" eval="True"/>
    </record>

    <record id="email_template_audit_reminder" model="mail.template">
        <field name="name">Audit Report Reminder</field>
        <field name="model_id" ref="base.model_res_partner"/>
        <field name="email_from">{{ (object.company_id.email_formatted or user.email_formatted) }}</field>
        <field name="partner_to">{{ object.id }}</field>
        <field name="subject">Audit Report Reminder for {{ object.name }}</field>
        <field name="body_html" type="html">
            <div>
                <p>Dear <t t-out="object.name or ''"/>,</p>
                <p>This is a reminder to submit your Audit Report for the year-to-date.</p>
                <p>Best regards,<br/>Company</p>
            </div>
        </field>
        <field name="lang">{{ object.lang }}</field>
        <field name="auto_delete" eval="True"/>
    </record>

    <record id="email_template_passport_reminder" model="mail.template">
        <field name="name">Passport Expiry Reminder</field>
        <field name="model_id" ref="base.model_res_partner"/>
        <field name="email_from">{{ (object.company_id.email_formatted or user.email_formatted) }}</field>
        <field name="partner_to">{{ object.id }}</field>
        <field name="subject">Passport Expiry Reminder for {{ object.name }}</field>
        <field name="body_html" type="html">
            <div style="margin: 0; padding: 0;">
                <p>Dear <t t-out="object.name or ''"/>,</p>
                <p>
                    This is a friendly reminder that your passport is set to expire on
                    <b><t t-out="object.passport_exp_date or 'N/A'"/></b>.
                </p>
                <p>
                    Please make sure to renew it before the expiry date to avoid any inconvenience.
                </p>
                <p>
                    Best regards,<br/>
                    <t t-out="user.name or 'Your Company'"/>
                </p>
            </div>
        </field>
        <field name="lang">{{ object.lang }}</field>
        <field name="auto_delete" eval="True"/>
    </record>

    <!-- Invoice Payment Due Reminder Template -->
    <record id="email_template_payment_due_reminder" model="mail.template">
        <field name="name">Invoice Payment Due Reminder</field>
        <field name="model_id" ref="account.model_account_move"/>
        <field name="email_from">{{ (object.company_id.email_formatted or user.email_formatted) }}</field>
        <field name="partner_to">{{ object.partner_id.id }}</field>
        <field name="subject">{{ object.company_id.name }} - Payment Due Reminder ({{ object.name or 'n/a' }})</field>
        <field name="description">Reminder email sent to customers when their invoice payment is due.</field>
        <field name="body_html" type="html">
            <div style="margin: 0px; padding: 0px;">
                <p style="font-size: 13px;">
                    Dear <t t-out="object.partner_id.name or ''"></t>,
                    <br/><br/>
                    This is a friendly reminder that payment for your invoice is due.
                    <br/><br/>
                    <ul>
                        <li><strong>Invoice Number:</strong> <t t-out="object.name or ''"/></li>
                        <li><strong>Invoice Date:</strong> <t t-out="format_date(object.invoice_date)"/></li>
                        <li><strong>Due Date:</strong> 
                            <t t-if="object.invoice_date_due">
                                <t t-out="format_date(object.invoice_date_due)"/>
                            </t>
                            <t t-else="">Not specified</t>
                        </li>
                        <li><strong>Total Amount:</strong> <t t-out="format_amount(object.amount_total, object.currency_id)"/></li>
                        <li><strong>Amount Due:</strong> <t t-out="format_amount(object.amount_residual, object.currency_id)"/></li>
                    </ul>
                    <br/>
                    Please make the payment at your earliest convenience to avoid any late penalties.
                    <br/><br/>
                    Thank you for your business.
                    <br/><br/>
                    Best regards,<br/>
                    <t t-out="object.company_id.name or ''"/>
                    <t t-if="not is_html_empty(user.signature)">
                        <br/><br/><t t-out="user.signature or ''"/>
                    </t>
                </p>
            </div>
        </field>
        <field name="lang">{{ object.partner_id.lang }}</field>
        <field name="auto_delete" eval="True"/>
    </record>
</odoo>
