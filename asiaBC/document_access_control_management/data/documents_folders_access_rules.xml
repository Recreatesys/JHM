<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Record Rule for Documents Folders -->
        <record id="documents_folders_portal_upload_access" model="ir.rule">
            <field name="name">Upload Access for Portal Users</field>
            <field name="model_id" ref="documents_portal_management.model_documents_folders"/>
            <field name="domain_force">[('upload_access_group', 'in', [user.id])]</field>
            <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>
    </data>
</odoo>
