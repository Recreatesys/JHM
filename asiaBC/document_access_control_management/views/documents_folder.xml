<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="inherit_folder_view_form" model="ir.ui.view">
    <field name="name">Folder Form View</field>
    <field name="model">documents.folders</field>
    <field name="inherit_id" ref="documents_portal_management.folder_view_form"/>
    <field name="arch" type="xml">
        <xpath expr="//field[@name='company_id']" position="after">
            <field name="upload_access" widget="many2many_tags"/>
            <field name="read_access" widget="many2many_tags"/>
        </xpath>
    </field>
</record>

</odoo>