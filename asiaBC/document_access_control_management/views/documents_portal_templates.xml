<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <template id="upload_portal_document_inherit"
                  inherit_id="documents_portal_management.my_attendance_upload_portal_documents">
            
            <xpath expr="//form[@action='/my/documents/upload_portal_documents/upload']/parent::div"
                   position="replace">
                
                <div class="o_documents_container d-flex">
                    <form id="upload_portal_documents_form" action="/my/documents/upload_portal_documents/upload"
                          method="post"
                          enctype="multipart/form-data">
                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                        <div class="w-100 d-flex justify-content-between text-nowrap" style="gap: 150px !important;">

                            <div class="form-group row">
                                <label for="staticDocuments" class="col-sm-4 col-form-label">
                                    Choose File
                                </label>
                                <div class="col-sm-8 position-relative">
                                    <span class="error-msg upload-error">Please Upload File</span>
                                    <input
                                            name="upload_documents"
                                            id="upload_documents"
                                            type="file"
                                            multiple="true"
                                            data-show-upload="true"
                                            data-show-caption="true"
                                            class="file"
                                            data-show-preview="true"
                                            required="required"/>
                                    <div class="col-sm-8 pt-2">
                                        <button id="btn_upload_docs" class="btn btn-primary mt16" type="button">Upload
                                        </button>
                                    </div>
                                </div>

                            </div>
                            <div class="form-group row gap-3">
                                <label for="folder_selection" class="col-sm-2 col-form-label">
                                    Folder:
                                </label>
                                <div class="col-sm-8 position-relative">
                                    <span class="error-msg folder-error">Choose Any One Folder</span>

                                    <select
                                            name="folder_selection"
                                            id="folder_selection"
                                            required="required">
                                        <option value="nofolder" selected="selected" disabled="disabled"
                                                hidden="hidden">No Folder
                                        </option>
                                        <t t-foreach="directories" t-as="directory">
                                            <option t-att-value="directory['id']" t-esc="directory['name']"/>
                                        </t>
                                    </select>
                                </div>
                            </div>
                        </div>

                    </form>
                </div>
                <style>
                    select#folder_selection {
                    min-width: 180px;
                    border: 1px solid lightgrey;
                    background: white;
                    border-radius: 7px;
                    padding: 8px 9px;
                    box-shadow: none;
                    outline: none;
                    }
                    .card.mt-0.rounded {upload_portal_document_inherit
                    margin-bottom: 20px;
                    }
                    .upload-error{
                    display:none;
                    }
                    .folder-error{
                    display:none;
                    }
                    .error-msg {
                    position: absolute;
                    top: 40px;
                    left: 18px;
                    color: red;
                    font-size: 11px;
                    font-style: italic;
                    }
                </style>
                <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"
                        integrity="sha512-v2CJ7UaYy4JwqLDIrZUI/4hqeoQieOmAZNXBeQyjo21dadnwR+8ZaIJVT8EE2iyI61OV8e6M8PP2/4hpQINQ/g=="
                        crossorigin="anonymous" referrerpolicy="no-referrer"></script>
                <script>

                    $(document).on("click","#btn_upload_docs",function(){
                    var chooseFileCount = $("input#upload_documents");
                    var FolderSelect = $("#folder_selection").find('option:selected').val();
                    if(chooseFileCount.get(0).files.length != 0 &amp;&amp; FolderSelect!= "nofolder"){
                    $("#upload_portal_documents_form").submit();
                    }
                    else{
                    if(chooseFileCount.get(0).files.length === 0){
                    $(".upload-error").fadeIn();
                    }
                    else{
                    $(".upload-error").hide();
                    }
                    if(FolderSelect== "nofolder"){
                    $(".folder-error").fadeIn();
                    }
                    else{
                    $(".folder-error").hide();
                    }
                    }

                    });

                    $('#upload_documents').change(function () {
                    const fileInput = $(this).get(0);
                    if (fileInput.files.length === 0) {
                    $(".upload-error").fadeIn();
                    } else {
                    $(".upload-error").fadeOut();
                    }
                    });
                    $('#folder_selection').change(function () {
                    debugger;
                    const folderValue = $(this).val();
                    if (folderValue === "nofolder") {
                    $(".folder-error").fadeIn();
                    } else {
                    $(".folder-error").fadeOut();
                    }
                    });

                </script>
            </xpath>
        </template>
        
        <template id="portal_my_documents_inherit" inherit_id="documents_portal_management.portal_my_documents">
            <xpath expr="//t[@t-call='portal.portal_layout']" position="replace">
                <t t-call="portal.portal_layout">
                    <t t-set="breadcrumbs_searchbar" t-value="True"/>
                    <t t-call="portal.portal_searchbar">
                        <t t-set="title">Documents</t>
                        <div class="ms-lg-2" t-if="request.env.user">
                            <a class="btn btn-primary" name='upload_portal_documents' title="Upload Portal Document"
                               href="/my/documents/upload_portal_documents">
                                <i class="fa fa-upload"/>
                                Upload Portal Document
                            </a>
                        </div>
                    </t>
                    <t t-if="not documents">
                        <p>There are currently no documents for your account.</p>
                    </t>

                    <t t-if="documents" t-call="portal.portal_table">
                        <t t-foreach="grouped_documents" t-as="document">
                            <thead>
                                <tr t-attf-class="{{'thead-light' if not groupby == 'none' else ''}}">
                                    <th t-if="groupby == 'none'">Document #</th>
                                    <th t-else="">
                                        <em class="font-weight-normal text-muted">Document #:</em>
                                        <span t-field="document[0].folder_id.name"/>
                                    </th>
                                    <th class="text-left">Name</th>
                                    <th class="text-left">Description</th>
                                    <th class="text-left">Mime Type</th>
                                    <th class="text-left">Create Date</th>
                                    <th class="text-left">Folder</th>
                                    <th class="text-center">Download</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="document" t-as="document">
                                    <t t-set="document_url"
                                       t-value="base_url + '/web/content/ir.attachment/' + str(document.id)"/>
                                    <tr>
                                        <td>
                                            <t t-if="document.is_personal_directory and not document.res_model">
                                                <span class="badge badge-success">
                                                    <i class="fa fa-user"></i>
                                                </span>
                                            </t>
                                            <t t-if="document.res_model">
                                                <span class="badge badge-primary">
                                                    <i class="fa fa-user"></i>
                                                </span>
                                            </t>
                                            <a target="_blank"
                                               t-att-href="'/web/get_attachments_data?id=' + str(document.id)">
                                                <t t-esc="document.code"/>
                                            </a>
                                            <t t-if="document.is_shared_file">
                                                <span>(Owner:</span>
                                                <span t-field="document.create_uid.name"/>
                                                <span>)</span>
                                            </t>
                                        </td>
                                        <td>
                                            <span t-field="document.name"/>
                                        </td>
                                        <td>
                                            <span t-field="document.description"/>
                                        </td>
                                        <td>
                                            <span t-field="document.mimetype"/>
                                        </td>
                                        <td>
                                            <span t-field="document.create_date"/>
                                        </td>
                                        <td>
                                            <span t-field="document.folder_id.name"/>
                                            <t t-if="document.is_shared_file">
                                                <span class="badge badge-info">
                                                    <i class="fa fa-share"></i>
                                                </span>
                                            </t>
                                        </td>
                                        <td style="text-align: center;" class="portal-attachment-download">
                                            <button class="border-0">
                                                <i class="fa fa-download fa-1x" role="img" aria-label="Download"
                                                   t-att-data-attachment-id="document.id"></i>
                                            </button>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </t>
                    </t>
                </t>

            </xpath>
        </template>
        
    </data>
</odoo>