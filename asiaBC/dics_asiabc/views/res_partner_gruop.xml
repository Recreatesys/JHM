<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!-- Group List View -->
    <record id="view_partner_group_list" model="ir.ui.view">
        <field name="name">res.partner.group.list</field>
        <field name="model">res.partner.group</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <!--                <field name="contact_ids"/>-->
            </list>
        </field>
    </record>

    <!-- Group Form View -->
    <record id="view_partner_group_form" model="ir.ui.view">
        <field name="name">res.partner.group.form</field>
        <field name="model">res.partner.group</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_contacts"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-address-book">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_value">
                                    <field name="contact_count"/>
                                </span>
                                <span class="o_stat_text">Contacts</span>
                            </div>
                        </button>
                    </div>
                    <group>
                        <field name="name"/>
                        <!--                        <field name="contact_ids">-->
                        <!--                            <list editable="bottom">-->
                        <!--                                <field name="name"/>-->
                        <!--                                <field name="company_type"/>-->
                        <!--                                <field name="phone"/>-->
                        <!--                                <field name="email"/>-->
                        <!--                            </list>-->
                        <!--                        </field>-->
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Group Action -->
    <record id="action_res_partner_group" model="ir.actions.act_window">
        <field name="name">Contact Groups</field>
        <field name="res_model">res.partner.group</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Menu Item for Groups -->
    <menuitem id="menu_res_partner_group" name="Groups" parent="contacts.menu_contacts"
              action="action_res_partner_group"/>
</odoo>
