<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Define a list view for ResPartner focusing on Directors -->

    <record id="view_res_partner_director_tree" model="ir.ui.view">
        <field name="name">res.partner.director.list</field>
        <field name="model">res.partner</field>
        <field name="arch" type="xml">
            <list string="Directors">
                <field name="name" string="Director Name"/>
                <field name="director_company_count" string="Company Count"/>
            </list>
        </field>
    </record>


    <!-- Define a simplified form view for Directors -->
    <record id="view_res_partner_director_form" model="ir.ui.view">
        <field name="name">res.partner.director.form</field>
        <field name="model">res.partner</field>
        <field name="arch" type="xml">
            <form string="Director">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="director_company_count" string="Company Count"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Define the action for Directors -->
    <record id="action_res_partner_director" model="ir.actions.act_window">
        <field name="name">Directors</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('is_company', '=', False)]</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                This view displays individual contacts who are directors and the count of companies they manage.
            </p>
        </field>
    </record>

    <!-- Menu Item for Directors -->
    <menuitem id="menu_res_partner_director_root"
              name="Directors"
              parent="contacts.menu_contacts"
              sequence="20"
              action="action_res_partner_director"/>
</odoo>
