<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <!--    Account  Invoice-->
        <record id="custom_paper_format_invoice" model="report.paperformat">
            <field name="name">Invoices</field>
            <field name="default" eval="False"/>
            <field name="format">A4</field>
            <field name="orientation">Portrait</field>
            <field name="margin_top">70</field>
            <field name="header_spacing">65</field>
            <field name="margin_bottom">15</field>
            <field name="margin_left">5</field>
            <field name="margin_right">5</field>
            <field name="header_line" eval="False"/>
        </record>

        <record id="account.account_invoices" model="ir.actions.report">
            <field name="name">Invoices</field>
            <field name="model">account.move</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">account.report_invoice_with_payments</field>
            <field name="report_file">account.report_invoice_with_payments</field>
            <field name="print_report_name">(object._get_report_base_filename())</field>
            <field name="attachment">
                (object.state == 'posted') and ((object.name or 'INV').replace('/','_')+'.pdf')
            </field>
            <field name="paperformat_id" ref="dics_asiabc.custom_paper_format_invoice"/>
            <field name="binding_model_id" ref="account.model_account_move"/>
            <field name="binding_type">report</field>
            <field name="groups_id"
                   eval="[(4, ref('account.group_account_invoice')), (4, ref('account.group_account_readonly'))]"/>
        </record>

        <record id="custom_paper_format_invoice_payments" model="report.paperformat">
            <field name="name">Payment Receipt</field>
            <field name="default" eval="False"/>
            <field name="format">A4</field>
            <field name="orientation">Portrait</field>
            <field name="margin_top">50</field>
            <field name="header_spacing">45</field>
            <field name="margin_bottom">15</field>
            <field name="margin_left">5</field>
            <field name="margin_right">5</field>
            <field name="header_line" eval="False"/>
        </record>

        <record id="account.action_report_payment_receipt" model="ir.actions.report">
            <field name="name">Payment Receipt</field>
            <field name="model">account.payment</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">account.report_payment_receipt</field>
            <field name="report_file">account.report_payment_receipt</field>
            <field name="binding_model_id" ref="account.model_account_payment"/>
            <field name="paperformat_id" ref="dics_asiabc.custom_paper_format_invoice_payments"/>
            <field name="binding_type">report</field>
        </record>
    </data>
</odoo>