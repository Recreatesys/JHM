<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="crm_res_config_settings_view_form_inherit" model="ir.ui.view">
        <field name="name">crm.res.config.settings.view.form.inherit</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="crm.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//block[setting/field[@name='is_membership_multi']]" position="after">
                <block>
                    <setting help="Enable this option to create opportunities directly from facebook leads.">
                        <field name="fb_lead_create_as_opportunity"/>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>
</odoo>
